# Envoi des formulaires vers contact@studioweb15.fr (Resend)
# À configurer dans Vercel : Project → Settings → Environment Variables

# Clé API Resend (obligatoire pour l'envoi)
# Créer un compte sur https://resend.com et récupérer la clé
RESEND_API_KEY=rexxxx

# Optionnel : adresse expéditrice (si domaine vérifié sur Resend)
# Sinon Resend utilise onboarding@resend.dev en test
# RESEND_FROM_EMAIL=Studio Web 15 <noreply@studioweb15.fr>
