# Envoi des formulaires (Resend)
# À configurer dans Vercel : Project → Settings → Environment Variables

# --- Référencement (production) ---
# URL publique du site. En production = https://studioweb15.fr
# Si absent ou contenant "staging" / "vercel.app", robots.txt bloque l'indexation.
NEXT_PUBLIC_SITE_URL=https://studioweb15.fr

# Vérification Google Search Console (optionnel mais recommandé)
# Après ajout du site dans search.google.com/search-console, coller ici le code de vérification (meta tag).
# NEXT_PUBLIC_GOOGLE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend ---
# Clé API Resend (obligatoire pour l'envoi)
# Créer un compte sur https://resend.com et récupérer la clé
RESEND_API_KEY=rexxxx

# Destinataire réel des messages (optionnel)
# Si défini, les emails arrivent ici au lieu de contact@studioweb15.fr (pratique si pas de redirection OVH)
# CONTACT_EMAIL_DESTINATION=studiowebcantal@gmail.com

# Optionnel : adresse expéditrice (si domaine vérifié sur Resend)
# Sinon Resend utilise onboarding@resend.dev en test
# RESEND_FROM_EMAIL=Studio Web 15 <noreply@studioweb15.fr>
